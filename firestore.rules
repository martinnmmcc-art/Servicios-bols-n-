rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────
    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return request.auth.uid == uid; }
    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Profiles ──────────────────────────────────────────
    match /profiles/{uid} {
      allow read: if isAuth();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Proyectos ─────────────────────────────────────────
    match /proyectos/{docId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.profesional_id == request.auth.uid;
      allow update, delete: if isAuth() &&
        resource.data.profesional_id == request.auth.uid;
    }

    // ── Comercios ─────────────────────────────────────────
    match /comercios/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAuth() &&
        (resource.data.owner_id == request.auth.uid || isAdmin());
    }

    // ── Solicitudes ───────────────────────────────────────
    match /solicitudes/{docId} {
      allow read: if isAuth() && (
        resource.data.cliente_id == request.auth.uid ||
        resource.data.profesional_id == request.auth.uid
      );
      allow create: if isAuth() &&
        request.resource.data.cliente_id == request.auth.uid;
      allow update: if isAuth() && (
        resource.data.cliente_id == request.auth.uid ||
        resource.data.profesional_id == request.auth.uid
      );
      allow delete: if isAuth() &&
        resource.data.cliente_id == request.auth.uid;
    }

    // ── Citas ─────────────────────────────────────────────
    match /citas/{docId} {
      allow read: if isAuth() && (
        resource.data.cliente_id == request.auth.uid ||
        resource.data.profesional_id == request.auth.uid
      );
      allow create: if isAuth() &&
        request.resource.data.cliente_id == request.auth.uid;
      allow update: if isAuth() && (
        resource.data.cliente_id == request.auth.uid ||
        resource.data.profesional_id == request.auth.uid
      );
      allow delete: if isAuth() &&
        resource.data.cliente_id == request.auth.uid;
    }

    // ── Conversaciones ────────────────────────────────────
    match /conversaciones/{docId} {
      allow read, write: if isAuth() &&
        request.auth.uid in resource.data.participantes;
      allow create: if isAuth() &&
        request.auth.uid in request.resource.data.participantes;
    }

    // ── Logs moderación (solo admin lee) ──────────────────
    match /actividad_log/{docId} {
      allow read: if isAdmin();
      allow create: if isAuth();
    }

    // ── Reportes ──────────────────────────────────────────
    match /reportes/{docId} {
      allow read: if isAdmin();
      allow create: if isAuth();
    }
  }
}
